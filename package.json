{
  "name": "@uscreen.de/postal-mailer",
  "type": "module",
  "version": "2.0.1",
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "description": "Mailer engine using mjml templates to send mail via postal api or smtp",
  "author": "Marcus Spiegel <spiegel@uscreen.de>",
  "license": "MIT",
  "homepage": "https://github.com/uscreen/postal-mailer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uscreen/postal-mailer.git"
  },
  "exports": {
    ".": "./index.js"
  },
  "main": "index.js",
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:cov": "c8 --reporter=html --reporter=text node --test test/*.test.js",
    "test:ci": "c8 --reporter=lcov --reporter=text node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@atech/postal": "^1.0.0",
    "env-schema": "^7.0.0",
    "globby": "^16.2.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "html-to-text": "^10.0.0",
    "mjml": "^5.0.1",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@uscreen.de/dev-service": "^0.14.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "nock": "^14.0.12"
  },
  "services": [
    {
      "image": "axllent/mailpit:latest",
