{
  "name": "@uscreen.de/postal-mailer",
  "type": "module",
  "version": "1.2.0",
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "description": "Mailer engine using mjml templates to send mail via postal api or smtp",
  "author": "Marcus Spiegel <spiegel@uscreen.de>",
  "license": "MIT",
  "homepage": "https://github.com/uscreen/postal-mailer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uscreen/postal-mailer.git"
  },
  "exports": {
    ".": "./index.js"
  },
  "main": "index.js",
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:cov": "c8 --reporter=html --reporter=text node --test test/*.test.js",
    "test:ci": "c8 --reporter=lcov --reporter=text node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@atech/postal": "^1.0.0",
    "env-schema": "^7.0.0",
    "globby": "^16.1.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "html-to-text": "^9.0.5",
    "mjml": "^4.18.0",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@uscreen.de/dev-service": "^0.13.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "nock": "^14.0.11"
  },
  "services": [
    {
      "image": "axllent/mailpit:latest",
      "ports": [
        "1025:1025",
        "8025:8025"
      ]
    }
  ]
